{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PodCodex",
  "version": "0.1.0-rc.2",
  "identifier": "com.podcodex.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build --prefix frontend"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PodCodex",
        "width": 1280,
        "height": 800,
        "minWidth": 860,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi"],
    "externalBin": [
      "binaries/podcodex-server",
      "binaries/ffmpeg",
      "binaries/yt-dlp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "Entitlements.plist"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "category": "Productivity",
    "shortDescription": "Transcribe, translate, and search your podcasts.",
    "longDescription": "Local-first desktop app that ingests podcasts, YouTube channels, lectures, or interviews; transcribes with WhisperX + pyannote diarization; corrects and translates via LLM; and indexes everything into a LanceDB vector store for semantic search."
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "REPLACE_ME",
      "endpoints": [
        "https://github.com/gabriel-jung/PodCodex/releases/latest/download/latest.json"
      ]
    }
  }
}
