# Copy to .env.production and fill in values

# Required
DISCORD_TOKEN=

# Path to the LanceDB index directory (built locally, rsynced here)
PODCODEX_INDEX=/app/data/index

# LLM provider for /ask — set the key for whichever provider you configure
# via /setup ask_provider:openai (or mistral / anthropic / custom)
OPENAI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
# Generic fallback if provider env var is not set
# ASK_API_KEY=
