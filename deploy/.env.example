# deploy/.env.example — copy to deploy/.env and fill in values.
# Used by the Docker install path. The uv path uses `.env` at the repo root.

# Required — your Discord bot token.
DISCORD_TOKEN=

# Optional — for /ask (LLM synthesis). Set the key for whichever provider you use.
# OPENAI_API_KEY=
# MISTRAL_API_KEY=
# ANTHROPIC_API_KEY=
